# Required for POST /api/chat (OpenRouter — https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model id on OpenRouter (default: openai/gpt-4o-mini)
OPENROUTER_MODEL=openai/gpt-4o-mini

# Embeddings model id on OpenRouter (default: text-embedding-3-small)
OPENROUTER_EMBEDDINGS_MODEL=text-embedding-3-small

# Optional OpenRouter attribution headers
# OPENROUTER_HTTP_REFERER=https://your-site.example
# OPENROUTER_APP_NAME=ShieldBase Insurance

# Server bind (optional)
# PORT=3001
# HOST=0.0.0.0

# Session/checkpoint settings (optional)
# CHAT_CHECKPOINT_DB_PATH=./data/chat-checkpoints.sqlite
# CHAT_CHECKPOINT_MAX_PER_THREAD=
# QUOTE_DRAFT_TTL_MINUTES=60

# RAG tuning (optional)
# RAG_MIN_COSINE_SIMILARITY=0.25
# RAG_RRF_K=60
# RAG_EMBEDDING_CACHE_DIR=~/.cache/shieldbase-rag
